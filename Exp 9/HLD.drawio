        <mxCell id="DmhbiSi0fAD6Grmr4eNj-4" parent="1" style="whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="160" width="116" x="244" y="820" as="geometry" />
        </mxCell>
        <mxCell id="Wr1eOBJt54A5HowGT5JR-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=#FF0000;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;&lt;u&gt;TICKET BOOKING SERVICE LIKE BookMyShow&lt;/u&gt;&lt;/b&gt;&lt;div&gt;&lt;b&gt;Online platform that allows user to purchase tickets of movies, events, etc&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="470" x="220" y="50" as="geometry" />
        </mxCell>
        <mxCell id="Wr1eOBJt54A5HowGT5JR-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="I. FUNCTIONAL REQUIREMENTS&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. SEARCH: user should be able to search event based on title, location, date&lt;/div&gt;&lt;div&gt;2. EVENT INFORMATION: user should be able to view details (seats, metadata, description)&lt;/div&gt;&lt;div&gt;3. BOOKING TICKET: booking for an event&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="300" x="80" y="110" as="geometry" />
        </mxCell>
        <mxCell id="Wr1eOBJt54A5HowGT5JR-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="II. NON - FUNCTIONAL REQUIREMENTS&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. TARGET: 100 Million DAU&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. AVAILABILITY: system must be always online , better show older data than error&lt;/div&gt;&lt;div&gt;3. CONSISTENCY: two people should never be able to book exact same seat for exact same date&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;available - view details + search&lt;/div&gt;&lt;div&gt;consistent - book ticket&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="300" x="460" y="110" as="geometry" />
        </mxCell>
        <mxCell id="Wr1eOBJt54A5HowGT5JR-7" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="III. CORE ENTITIES&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. USER&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. EVENT&lt;/div&gt;&lt;div&gt;3. VENUE&lt;/div&gt;&lt;div&gt;4. TICKET&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="300" x="80" y="390" as="geometry" />
        </mxCell>
        <mxCell id="Wr1eOBJt54A5HowGT5JR-9" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="IV. API DESIGN&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. GET: /v1/search/?q={searchTerm}&amp;amp;location={loc}&amp;amp;date={date} -&amp;gt; List&amp;lt;EventId&amp;gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp;+ PAGINATION&lt;/div&gt;&lt;div&gt;2. GET/v1/event/{eventId} -&amp;gt; Event details + location + Seats[]&lt;/div&gt;&lt;div&gt;3. POST/v1/booking/reserve&lt;/div&gt;&lt;div&gt;{&lt;/div&gt;&lt;div&gt;&amp;nbsp;List&amp;lt;Seats&amp;gt; seats;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="300" x="370" y="390" as="geometry" />
        </mxCell>
        <mxCell id="Wr1eOBJt54A5HowGT5JR-11" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="/v1/booking/confirm&lt;div&gt;{&lt;/div&gt;&lt;div&gt;bookingId, paymentDetails&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="550" y="535" as="geometry" />
        </mxCell>
        <mxCell id="Wr1eOBJt54A5HowGT5JR-12" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="HIGH LEVEL DESIGN" vertex="1">
